# EVEZ AI Provider — Environment Configuration
# Copy this to .env and fill in your values

# Required: At least one backend API key
VULTR_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Optional: Additional backends (uncomment and fill as needed)
# TOGETHER_API_KEY=
# DEEPINFRA_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# SILICONFLOW_API_KEY=
# FIREWORKS_API_KEY=
# OPENAI_API_KEY=

# Server
PROVIDER_PORT=9100

# Admin — MUST be set to a strong random value for model management
ADMIN_KEY=

# Rate limiting
RATE_LIMIT_RPM=60
