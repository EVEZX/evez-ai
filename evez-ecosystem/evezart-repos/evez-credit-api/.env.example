# EVEZ Credit API — Environment Variables
# Copy to .env and fill in values

# Server
PORT=8080

# Database (currently SQLite, path relative to app dir)
DB_PATH=credit_api.db

# Auth
# Master admin key for internal operations (leave empty to disable admin routes)
ADMIN_KEY=

# Stripe (future)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
