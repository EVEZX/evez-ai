# EVEZ OpenClaw — Environment Variables
# Copy to .env and fill in your keys
# =====================================

# PRIMARY PROVIDERS (your current keys)
GROQ_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=

# SEARCH & WEB
APIFY_TOKEN=
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
SEARXNG_URL=

# ADDITIONAL MODEL PROVIDERS
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
DEEPINFRA_API_KEY=
NOVITA_API_KEY=
HUGGINGFACE_TOKEN=

# VOICE & MEDIA
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# CHANNELS
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SIGNAL_PHONE_NUMBER=

# MEDIA GENERATION
FAL_KEY=
RUNWAY_API_KEY=
OPENCLAW_MEDIA_DIR=~/.openclaw/media
OPENCLAW_ARTIFACT_PORT=18888
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility,video

# AUTH & INFRASTRUCTURE
CLERK_SECRET_KEY=
CONVEX_DEPLOY_KEY=

# OPENCLAW RUNTIME
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AUTH_TOKEN=
OPENCLAW_URL=
OPENCLAW_TOKEN=
CLAWD_URL=
CLAWD_TOKEN=
CK_TOKEN=
EVEZ_CK_TOKEN=
OPENCLAW_PORT=18789
OPENCLAW_BIND=loopback
OPENCLAW_STATE_DIR=~/.openclaw
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
OPENCLAW_TELEGRAM_ALLOW_FROM=
OPENCLAW_PUBLIC_URL=
OPENCLAW_LAN_URL=

# OPTIONAL DEPLOY SURFACES
FLY_API_TOKEN=
RAILWAY_TOKEN=
RENDER_API_KEY=
REPLIT_TOKEN=
VITE_OPENCLAW_DEFAULT_URL=

# AGENTVAULT CONNECTOR PROFILE
AGENTVAULT_CONNECTOR_CONFIG=~/.openclaw/agentvault-connector.json
AGENTVAULT_ATTESTATION=tpm2
AGENTVAULT_AUDIT_LOG=true
AGENTVAULT_ROTATION_INTERVAL_HOURS=24
AGENTVAULT_ZERO_KNOWLEDGE=true
