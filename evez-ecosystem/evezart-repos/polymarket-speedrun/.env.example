# ============================================================
# POLYMARKET SPEED-RUN BOT — Environment Config
# ============================================================
# Copy this to .env and fill in your values
# NEVER commit .env to git

# --- WALLET ---
# Your Ethereum private key (with 0x prefix)
# This signs all Polymarket trades. KEEP THIS SECRET.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your wallet address
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# --- POLYMARKET CLOB API ---
# Get API key from: https://docs.polymarket.com
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_passphrase_here

# --- STRATEGY ---
# Max USD per single trade
MAX_BET_SIZE=2.00

# Total portfolio budget
TOTAL_BUDGET=10.00

# Minimum score threshold (0-100) to trigger auto-trade
MIN_SCORE_THRESHOLD=65

# Minimum payoff multiplier to consider
MIN_PAYOFF_MULTIPLIER=2.0

# Maximum days until resolution (speed filter)
MAX_DAYS_TO_RESOLVE=14

# --- EVIDENCE FEEDS ---
# CoinGecko API (free tier works)
COINGECKO_API_KEY=

# NewsAPI for headline scanning (optional)
NEWSAPI_KEY=

# --- EXECUTION ---
# dry_run = log trades but don't execute
# live = execute real trades
MODE=dry_run

# Scan interval in seconds
SCAN_INTERVAL=60

# --- NOTIFICATIONS (optional) ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
