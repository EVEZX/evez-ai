<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- OpenClaw often runs as a local/LAN gateway during A16/Termux use. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
