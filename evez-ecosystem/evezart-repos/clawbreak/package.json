{
  "name": "clawbreak-android",
  "version": "1.0.0",
  "description": "ClawBreak — AI Agent Platform (Android + Web)",
  "scripts": {
    "build": "cp -r www dist && echo 'Build done'",
    "cap:init": "npx cap init ClawBreak com.evez.clawbreak --web-dir www",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:build": "npx cap sync android",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
