{
  "version": 2,
  "builds": [
    { "src": "evez-monitoring-dashboard.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/evez-monitoring-dashboard.js" }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "LINEAR_API_KEY": "@linear_api_key"
  }
}
