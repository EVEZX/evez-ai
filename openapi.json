{
  "openapi": "3.1.0",
  "info": {
    "title": "EVEZ AI API",
    "description": "Free AI API — 35+ models, OpenAI-compatible, $0/month. No credit card required.",
    "version": "2.0.0",
    "contact": {"name": "EVEZ", "url": "https://evezx.github.io/evez-ai"}
  },
  "servers": [
    {"url": "https://evez-provider-production.up.railway.app/v1", "description": "Railway (primary)"},
    {"url": "http://66.42.125.106:9100/v1", "description": "Vultr (fallback)"}
  ],
  "paths": {
    "/signup": {
      "post": {
        "summary": "Create a free API key",
        "description": "Get an API key instantly. No credit card, no waiting. 60 requests/minute free tier.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["email"], "properties": {"email": {"type": "string", "format": "email"}, "name": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "API key created", "content": {"application/json": {"schema": {"type": "object", "properties": {"key": {"type": "string"}, "email": {"type": "string"}, "rate_limit": {"type": "string"}, "models": {"type": "integer"}, "base_url": {"type": "string"}, "message": {"type": "string"}}}}}}
        }
      }
    },
    "/chat/completions": {
      "post": {
        "summary": "Chat completion (OpenAI-compatible)",
        "tags": ["Chat"],
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["messages"], "properties": {"model": {"type": "string", "default": "evez-smart", "enum": ["evez-smart","evez-code","evez-fast","glm-5.1","deepseek-v3","kimi-k2"]}, "messages": {"type": "array", "items": {"type": "object", "required": ["role","content"], "properties": {"role": {"type": "string", "enum": ["system","user","assistant"]}, "content": {"type": "string"}}}}, "max_tokens": {"type": "integer", "default": 500}, "stream": {"type": "boolean", "default": false}}}}}
        },
        "responses": {
          "200": {"description": "Chat completion response"}
        }
      }
    },
    "/models": {
      "get": {
        "summary": "List available models",
        "tags": ["Models"],
        "responses": {"200": {"description": "Model list"}}
      }
    },
    "/health": {
      "get": {
        "summary": "Health check",
        "tags": ["System"],
        "responses": {"200": {"description": "Service health"}}
      }
    },
    "/key-info": {
      "get": {
        "summary": "Get API key info",
        "tags": ["Authentication"],
        "security": [{"BearerAuth": []}],
        "responses": {"200": {"description": "Key info"}}
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {"type": "http", "scheme": "bearer", "description": "API key from /v1/signup (optional — free tier works without key)"}
    }
  }
}
